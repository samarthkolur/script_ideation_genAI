# Copy this file to .env and fill in real values. .env is gitignored.

# NVIDIA NIM API key, from https://build.nvidia.com (org: Settings > API Keys).
# Used by ai/eval/* to call NIM's OpenAI-compatible endpoint.
NVIDIA_API_KEY=

# Base URL for NVIDIA NIM's OpenAI-compatible API. Override only if using
# a self-hosted NIM container instead of the hosted build.nvidia.com endpoint.
NVIDIA_NIM_BASE_URL=https://integrate.api.nvidia.com/v1
