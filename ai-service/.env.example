# Copy to .env (gitignored). This is a THIRD .env file in the repo, separate
# from both the project-root one (ai/eval/) and frontend/.env (the BFF) —
# each subsystem owns its own.

# "mock" (default) needs nothing below — deterministic, instant, no external
# calls. Use it for local dev / testing the rest of the system. "nim" makes
# real NVIDIA NIM calls and requires NIM_API_KEY.
MODEL_PROVIDER=mock

NIM_API_KEY=
NIM_BASE_URL=https://integrate.api.nvidia.com/v1
# Model must be entitled on your NIM account — verify with
# GET https://integrate.api.nvidia.com/v1/models before assuming a model
# ID works. See design.md §16 for why this matters (learned the hard way).
NIM_MODEL_NAME=minimaxai/minimax-m3

# Must match frontend/.env's AI_SERVICE_SHARED_SECRET exactly. Leave both
# blank for local dev; set both before any real deployment.
AI_SERVICE_SHARED_SECRET=
